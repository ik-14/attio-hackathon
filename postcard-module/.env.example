# ── Text stages (Stage 1/2/3a: distil, copy, image-prompt) ─────────────────
# Primary provider per execution-plan workstream B is SIE `generate`.
# Leave both unset to run with the deterministic mock (pipeline still produces a card).
TEXT_LLM_PROVIDER=sie            # sie | gemini | mock
SIE_BASE_URL=https://api.superlinked.com
SIE_API_KEY=
SIE_TEXT_MODEL=Qwen/Qwen3-4B-Instruct-2507

# ── Image stage (Stage 3b) — Google Gemini only (settled; SIE has no image primitive)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3.1-flash-image
GEMINI_TEXT_MODEL=gemini-3.5-flash

# ── Stage 6 — Lob (test mode) ──────────────────────────────────────────────
LOB_API_KEY=                      # use a test_ key — renders a proof PDF, no postage
LOB_FROM_NAME=Your Company
LOB_FROM_ADDRESS_LINE1=210 King St
LOB_FROM_CITY=San Francisco
LOB_FROM_STATE=CA
LOB_FROM_ZIP=94107
LOB_FROM_COUNTRY=US

# ── Attio write-back (teammates own the full client; this is a minimal shim) ─
ATTIO_API_KEY=
ATTIO_OBJECT=people

# ── Stage 5 checks ─────────────────────────────────────────────────────────
# The QR decode round-trip always runs. Reachability fetch is opt-in so the
# module runs offline during prep; set true on stage (host must NOT be localhost).
QR_REQUIRE_REACHABLE=false

# Where generated PDFs / assets / image cache are written.
OUT_DIR=./out
