# ── Text stages (Stage 1/2/3a: distil, copy, image-prompt) ─────────────────
# Leave TEXT_LLM_PROVIDER unset (or set to "mock") to run fully offline.
TEXT_LLM_PROVIDER=gemini          # gemini | mock
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image
GEMINI_IMAGE_FALLBACK_MODEL=gemini-3.1-flash-image
GEMINI_TEXT_MODEL=gemini-3.5-flash

# ── Sender context (sourced from Attio ICP config in production) ───────────
# In production these come from the ICP form saved in Attio.
# For demo, set them here. Omit to use the built-in fallback one-liners.
SENDER_WHAT_WE_DO=We send autonomous, AI-personalised physical outreach to your ICP — a real postcard, no manual work.
SENDER_ICP_DESCRIPTION=B2B sales teams and founders who want to stand out with personalised outreach at scale.

# ── Stage 6 — Lob (test mode) ──────────────────────────────────────────────
LOB_API_KEY=                      # use a test_ key — renders a proof PDF, no postage
LOB_FROM_NAME=Your Company
LOB_FROM_ADDRESS_LINE1=210 King St
LOB_FROM_CITY=San Francisco
LOB_FROM_STATE=CA
LOB_FROM_ZIP=94107
LOB_FROM_COUNTRY=US

# ── Attio write-back ────────────────────────────────────────────────────────
ATTIO_API_KEY=
ATTIO_OBJECT=people

# ── Stage 0 — brand kit fetch (domain → logo + palette) ───────────────────
# auto = fetch when brand_kit is omitted or incomplete on the mail input
# always = always fetch and merge (supplied fields override)
# never = use supplied/sector fallback only
BRAND_FETCH=auto
BRAND_FETCH_MISSING_LOGO=true     # in auto mode, fetch if palette present but no logo
BRANDFETCH_API_KEY=               # optional — Brandfetch is step 1 when set
BRAND_FETCH_TIMEOUT_MS=8000

# ── QR / booking link ───────────────────────────────────────────────────────
# In production: leave unset. The outreach-agent sets booking_url to the
#   tracked redirect (https://<host>/r/:trackingId) which logs engagement in
#   Attio then forwards to Calendly — this is how the "engaged" signal fires.
# For demo prep / QR smoke-tests: set CALENDLY_URL to your Calendly link and
#   the demo runner will encode it directly so the QR scans to a real page.
CALENDLY_URL=

# Reachability fetch is opt-in so the module runs offline during prep.
# Set true on stage (host must NOT be localhost).
QR_REQUIRE_REACHABLE=false

# Where generated PDFs / assets / image cache are written.
OUT_DIR=./out
